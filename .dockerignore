# =============================================================================
# 🐳 Docker Ignore File
# =============================================================================
# Files and directories to exclude from Docker builds
# =============================================================================

# Git
.git
.gitignore

# Dependencies (installed in container)
node_modules
*/node_modules

# Build artifacts
dist
*/dist
*.tsbuildinfo

# Development files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# Environment files (use Docker secrets in production)
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test files
coverage
.nyc_output
*.test.ts
*.spec.ts
__tests__
*.test.tsx
*.spec.tsx

# Documentation (optional - uncomment to include)
# docs
# *.md
# !README.md

# Data files (should be in volumes, not image)
data
*.db
*.sqlite
*.sqlite3

# Scripts not needed in container
*.bat
*.ps1
INTERACT.bat
START.bat

# GitHub
.github

# Docker files (prevent recursive copies)
Dockerfile*
docker-compose*
.dockerignore

# Misc
*.log
logs
tmp
temp
.cache
