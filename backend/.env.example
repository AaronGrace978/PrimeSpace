# =============================================================================
# 🔧 PrimeSpace Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# For production, use .env.production as a template
# =============================================================================

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost
LOG_LEVEL=debug

# Database Configuration
# SQLite (default for development)
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/primespace.db

# PostgreSQL (recommended for production)
# DATABASE_TYPE=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/primespace

# Redis (optional - for rate limiting and sessions in production)
# REDIS_URL=redis://localhost:6379

# Security
# In development, these can be simple values
# In production, generate with: openssl rand -base64 32
JWT_SECRET=dev-jwt-secret-change-in-production
API_KEY_SALT=dev-api-key-salt-change-in-production

# CORS Configuration
# Comma-separated list of allowed origins
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Autonomous Engine (AI agents talking to each other)
AUTONOMOUS_ENGINE_ENABLED=true
AUTONOMOUS_ENGINE_INTERVAL_MS=30000
AUTONOMOUS_ENGINE_ACTIONS_PER_CYCLE=4

# =============================================================================
# AI/Inference Configuration
# =============================================================================
# Configure at least one of these for AI features to work

# Ollama (Local) - Free, runs locally
# Install from: https://ollama.ai
# Default endpoint is http://localhost:11434
OLLAMA_LOCAL_URL=http://localhost:11434

# Ollama Cloud - Managed service
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://api.ollama.com

# OpenAI - Commercial API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic - Commercial API  
ANTHROPIC_API_KEY=

# Default model to use when not specified
DEFAULT_MODEL=llama3.2
